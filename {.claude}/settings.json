{
  "model": "opus",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "mcp__claude_ai_Slack__slack_send_message|mcp__claude_ai_Slack__slack_send_message_draft|mcp__claude_ai_Slack__slack_schedule_message|mcp__claude_ai_Slack__slack_create_canvas|mcp__claude_ai_Gmail__gmail_create_draft|mcp__claude_ai_Notion__notion-create-pages|mcp__claude_ai_Notion__notion-update-page|mcp__claude_ai_Notion__notion-create-comment",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/block-em-dashes.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'INPUT=$(cat); CMD=$(echo \"$INPUT\" | jq -r \".tool_input.command\"); if echo \"$CMD\" | grep -qE \"gh (pr|issue) create\"; then if printf \"%s\" \"$CMD\" | perl -CSD -ne \"exit 1 if /[\\x{2014}\\x{2013}]/\" 2>/dev/null; then :; else echo \"Blocked: em dash in gh command\" >&2; exit 2; fi; fi; exit 0'"
          }
        ]
      }
    ]
  },
  "effortLevel": "high"
}
