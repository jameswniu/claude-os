# Scene 7: The Cost
# Duration target: ~15 seconds
# Shows budget breakdown

Output scenes/scene-7-cost.mp4

Set Shell "zsh"
Set FontSize 18
Set Width 1280
Set Height 720
Set Theme "Dracula"
Set Padding 40
Set TypingSpeed 0ms
Set WindowBar Colorful

Hide
Type "clear"
Enter
Sleep 500ms
Show

Type "echo ''"
Enter
Type "echo ''"
Enter
Type "echo '  ╔══════════════════════════════════════════════════════════════╗'"
Enter
Type "echo '  ║                    Weekly Automation Cost                   ║'"
Enter
Type "echo '  ╠══════════════════════════════════════════════════════════════╣'"
Enter
Type "echo '  ║                                                            ║'"
Enter
Type "echo '  ║   Script          Frequency      Est. Cost/Week            ║'"
Enter
Type "echo '  ║   ─────────────   ────────────   ──────────────            ║'"
Enter
Type "echo '  ║   log             every 1h       ~\$1.50                    ║'"
Enter
Type "echo '  ║   distill         every 24h      ~\$0.80                    ║'"
Enter
Type "echo '  ║   promote         every 7d       ~\$0.40                    ║'"
Enter
Type "echo '  ║   sync-confluence every 24h      ~\$0.50                    ║'"
Enter
Type "echo '  ║   sync-notion     every 24h      ~\$0.50                    ║'"
Enter
Type "echo '  ║                                                            ║'"
Enter
Type "echo '  ║   TOTAL                          ~\$3.70/week               ║'"
Enter
Type "echo '  ║                                                            ║'"
Enter
Type "echo '  ║   Each script is budget-capped. No surprises.              ║'"
Enter
Type "echo '  ║                                                            ║'"
Enter
Type "echo '  ╚══════════════════════════════════════════════════════════════╝'"
Enter

Sleep 8s
