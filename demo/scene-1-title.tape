# Scene 1: Title Card - "The Problem"
# Duration target: ~14 seconds (audio: 12.3s)

Output scenes/scene-1-title.mp4

Set Shell "zsh"
Set FontSize 22
Set Width 1280
Set Height 720
Set Theme "Dracula"
Set Padding 60
Set TypingSpeed 0ms
Set WindowBar Colorful

Hide
Type "clear"
Enter
Sleep 500ms
Show

Type "echo ''"
Enter
Type "echo ''"
Enter
Type "echo ''"
Enter
Type "echo '  ╔══════════════════════════════════════════════════════════╗'"
Enter
Type "echo '  ║                                                        ║'"
Enter
Type "echo '  ║                      ClaudeOS                          ║'"
Enter
Type "echo '  ║                                                        ║'"
Enter
Type "echo '  ║     A Memory System for Claude Code                    ║'"
Enter
Type "echo '  ║                                                        ║'"
Enter
Type "echo '  ╚══════════════════════════════════════════════════════════╝'"
Enter
Type "echo ''"
Enter
Type "echo ''"
Enter
Type "echo '  Every session starts fresh. Claude doesnt remember your'"
Enter
Type "echo '  teams rules, your projects architecture, or the mistakes'"
Enter
Type "echo '  it made yesterday.'"
Enter
Type "echo ''"
Enter
Type "echo '  ClaudeOS fixes that.'"
Enter

Sleep 12s
